<style>

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {

  --bg:        #0d1117;

  --bg2:       #161b22;

  --bg3:       #1c2330;

  --border:    #30363d;

  --border2:   #3d444d;

  --muted:     #636e7b;

  --body:      #8b949e;

  --light:     #cdd9e5;

  --white:     #e6edf3;

  --cyan:      #39d0d8;

  --cyan-dim:  #1a6e73;

  --cyan-bg:   #0d2e30;

  --mono: 'JetBrains Mono', monospace;

  --display: 'Syne', sans-serif;

}

html { scroll-behavior: smooth; }

body { font-family: var(--mono); background: var(--bg); color: var(--body); font-size: 14px; line-height: 1.7; }



/* NAV */

nav {

  position: sticky; top: 0; z-index: 100;

  display: flex; justify-content: space-between; align-items: center;

  padding: 16px 5vw;

  background: rgba(13,17,23,0.9); backdrop-filter: blur(12px);

  border-bottom: 1px solid var(--border);

}

.nav-logo { font-family: var(--display); font-size: 20px; font-weight: 800; color: var(--cyan); letter-spacing: -0.5px; }

.nav-links { display: flex; gap: 24px; }

.nav-links a { text-decoration: none; color: var(--muted); font-size: 12px; letter-spacing: 0.5px; transition: color 0.2s; font-family: var(--mono); }

.nav-links a:hover { color: var(--cyan); }



/* HERO */

.hero { min-height: 90vh; display: flex; align-items: center; padding: 80px 5vw; position: relative; }

.hero-line {

  position: absolute; top: 0; left: 0; right: 0; bottom: 0; pointer-events: none;

  background-image: repeating-linear-gradient(0deg, transparent, transparent 39px, rgba(48,54,61,0.3) 39px, rgba(48,54,61,0.3) 40px);

}

.hero-content { position: relative; max-width: 700px; }

.hero-prompt { font-size: 12px; color: var(--cyan); margin-bottom: 24px; display: flex; align-items: center; gap: 8px; }

.hero-prompt::before { content: '>_'; font-weight: 500; }

.hero-name {

  font-family: var(--display); font-weight: 800;

  font-size: clamp(52px, 9vw, 100px);

  line-height: 0.9; color: var(--white);

  letter-spacing: -3px; margin-bottom: 8px;

}

.hero-name span { color: var(--cyan); }

.hero-handle { font-size: 13px; color: var(--muted); margin-bottom: 28px; letter-spacing: 0.3px; }

.hero-bio { color: var(--body); font-size: 14px; line-height: 1.85; max-width: 480px; margin-bottom: 32px; }

.hero-tags { display: flex; flex-wrap: wrap; gap: 8px; }

.hero-tag {

  border: 1px solid var(--border2); border-radius: 4px;

  padding: 5px 12px; font-size: 11px; color: var(--muted);

  letter-spacing: 0.4px;

}



/* SECTIONS */

section { padding: 80px 5vw; border-top: 1px solid var(--border); }

.sec-label {

  font-size: 11px; letter-spacing: 2px; text-transform: uppercase;

  color: var(--cyan); margin-bottom: 8px; display: flex; align-items: center; gap: 8px;

}

.sec-label::before { content: '//'; opacity: 0.5; }

.sec-heading {

  font-family: var(--display); font-weight: 700;

  font-size: clamp(28px, 5vw, 52px);

  color: var(--white); line-height: 1.05;

  letter-spacing: -1.5px; margin-bottom: 40px;

}



/* ABOUT */

.about-grid { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 60px; align-items: start; }

@media (max-width: 640px) { .about-grid { grid-template-columns: 1fr; } }

.about-body { color: var(--body); font-size: 13px; line-height: 1.9; }

.about-body p + p { margin-top: 16px; }

.code-block {

  background: var(--bg2); border: 1px solid var(--border);

  border-radius: 8px; padding: 20px 24px; font-size: 12px; line-height: 1.9;

}

.code-key { color: var(--cyan); }

.code-str { color: #a5d6ff; }

.code-num { color: #f7b955; }

.code-bracket { color: var(--muted); }

.code-comment { color: var(--muted); font-style: italic; }



/* ROBOTICS */

.rob-grid { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 60px; align-items: start; }

@media (max-width: 640px) { .rob-grid { grid-template-columns: 1fr; } }

.rob-body { color: var(--body); font-size: 13px; line-height: 1.9; }

.timeline { margin-top: 32px; }

.tl-item { display: flex; gap: 16px; padding: 16px 0; border-bottom: 1px solid var(--border); }

.tl-item:first-child { border-top: 1px solid var(--border); }

.tl-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--cyan); margin-top: 6px; flex-shrink: 0; }

.tl-year { font-size: 11px; color: var(--cyan); letter-spacing: 1px; margin-bottom: 2px; }

.tl-desc { font-size: 12px; color: var(--body); }

.stat-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

.stat-card {

  background: var(--bg2); border: 1px solid var(--border);

  border-radius: 8px; padding: 20px;

}

.stat-n { font-family: var(--display); font-size: 36px; font-weight: 700; color: var(--cyan); line-height: 1; margin-bottom: 4px; }

.stat-l { font-size: 11px; color: var(--muted); letter-spacing: 0.5px; }



/* YOUTUBE */

.yt-card {

  background: var(--bg2); border: 1px solid var(--border);

  border-radius: 10px; padding: 28px; max-width: 500px;

}

.yt-header { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; }

.yt-icon-box { width: 36px; height: 36px; background: #ff0000; border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }

.yt-icon-box svg { width: 18px; height: 18px; fill: white; }

.yt-name { font-family: var(--display); font-size: 18px; font-weight: 700; color: var(--white); }

.yt-body { font-size: 12px; color: var(--body); line-height: 1.8; margin-bottom: 16px; }

.yt-body a { color: var(--cyan); text-decoration: none; }

.yt-subs { display: flex; align-items: baseline; gap: 6px; }

.yt-subs-n { font-family: var(--display); font-size: 28px; font-weight: 700; color: var(--white); }

.yt-subs-l { font-size: 11px; color: var(--muted); }

.yt-tooltip-wrap { position: relative; display: inline-flex; align-items: center; margin-left: 4px; }

.yt-dots { display: inline-flex; gap: 3px; cursor: pointer; padding: 3px 6px; border-radius: 4px; transition: background 0.15s; }

.yt-dots:hover { background: var(--bg3); }

.yt-dots span { width: 3px; height: 3px; border-radius: 50%; background: var(--muted); display: block; }

.yt-tooltip { display: none; position: absolute; left: 0; top: calc(100% + 6px); background: var(--bg3); border: 1px solid var(--border2); color: var(--body); font-size: 11px; line-height: 1.65; border-radius: 8px; padding: 12px 14px; width: 220px; z-index: 10; }

.yt-tooltip-wrap.open .yt-tooltip { display: block; }



/* FUN FACTS */

.facts-section { background: var(--bg2); }

.facts-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(170px, 1fr)); gap: 12px; margin-top: 8px; }

.fact-card {

  background: var(--bg); border: 1px solid var(--border);

  border-radius: 8px; padding: 20px;

  transition: border-color 0.2s;

}

.fact-card:hover { border-color: var(--cyan-dim); }

.fact-emoji { font-size: 24px; margin-bottom: 10px; line-height: 1; }

.fact-title { font-family: var(--display); font-size: 14px; font-weight: 600; color: var(--light); margin-bottom: 4px; }

.fact-desc { font-size: 11px; color: var(--muted); line-height: 1.7; }



/* LINKS */

.links-grid { display: flex; flex-wrap: wrap; gap: 10px; }

.link-pill {

  display: inline-flex; align-items: center; gap: 8px;

  background: var(--bg2); border: 1px solid var(--border);

  border-radius: 6px; padding: 10px 16px;

  font-size: 12px; color: var(--body); text-decoration: none;

  transition: all 0.2s; letter-spacing: 0.2px;

}

.link-pill:hover { border-color: var(--cyan); color: var(--cyan); background: var(--cyan-bg); }

.link-pill svg { width: 14px; height: 14px; flex-shrink: 0; }



/* FOOTER */

.thank-section { text-align: center; padding: 60px 5vw; border-top: 1px solid var(--border); }

.thank-text { font-family: var(--display); font-size: clamp(24px, 5vw, 44px); font-weight: 700; color: var(--white); letter-spacing: -1px; }

.thank-sub { font-size: 12px; color: var(--muted); margin-top: 10px; }

.cursor { display: inline-block; width: 2px; height: 1em; background: var(--cyan); vertical-align: middle; margin-left: 3px; animation: blink 1s step-end infinite; }

@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }

</style>

</head>

